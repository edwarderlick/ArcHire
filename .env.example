# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Arc Testnet
VITE_ARC_RPC_URL=https://rpc.testnet.arc.network
VITE_ARC_CHAIN_ID=5042002

# USDC system contract on Arc (ERC-20 interface, 6 decimals)
VITE_USDC_CONTRACT_ADDRESS=0x3600000000000000000000000000000000000000

# Deployed escrow contract (fill after: cd contracts && npx hardhat run scripts/deploy.ts --network arcTestnet)
VITE_ESCROW_CONTRACT_ADDRESS=

# WalletConnect project ID — get one free at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Fallback wallet for agent payouts if Supabase agent has no owner_wallet set
VITE_AGENT_DEFAULT_WALLET=
